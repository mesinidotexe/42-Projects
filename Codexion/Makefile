NAME	= a.out
CC		= cc
CFLAGS	= -Wall -Wextra -Werror
SRCS	= main.c parser/main_parse.c parser/parse_utils.c
OBJS	= $(SRCS:.c=.o)


all: $(NAME)
$(NAME): $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) -o $(NAME)


%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@


clean:
	rm -f $(OBJS)


fclean: clean
	rm -f $(NAME)


re: fclean all


.PHONY: all clean fclean re